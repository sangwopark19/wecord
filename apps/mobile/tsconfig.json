{
  "extends": "../../tooling/typescript/expo.json",
  "compilerOptions": {
    "paths": {
      "@/*": [
        "./*"
      ],
      "@wecord/shared": [
        "../../packages/shared/src"
      ],
      "@wecord/shared/*": [
        "../../packages/shared/src/*"
      ]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".expo/types/**/*.ts",
    "nativewind-env.d.ts",
    "expo-env.d.ts",
    "types/**/*.d.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
